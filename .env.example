# Copy this file to .env and adjust values as needed.
# `.env` is git-ignored and is read automatically by docker-compose and,
# for local (non-container) runs, by the app itself via godotenv.

# ---- Application ----
APP_PORT=8080

# ---- PostgreSQL ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=employee_db
DB_SSLMODE=disable

# ---- Redis ----
REDIS_ADDR=localhost:6379
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- JWT auth ----
# Generate a strong secret for real deployments, e.g.: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRATION_MINUTES=60

# Demo credentials used by POST /api/v1/auth/login to obtain a token.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
